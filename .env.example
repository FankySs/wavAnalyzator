# ── Database (local dev) ───────────────────────────────────────────────────────
DATABASE_URL=file:apps/wav-api/prisma/dev.db

# ── Database (Turso – production) ─────────────────────────────────────────────
# DATABASE_URL=file:apps/wav-api/prisma/dev.db   # still required; used by Prisma CLI
# TURSO_DATABASE_URL=libsql://[workspace].turso.io
# TURSO_AUTH_TOKEN=your_turso_auth_token

# ── Server ─────────────────────────────────────────────────────────────────────
PORT=3000
CORS_ORIGINS=http://localhost:4200
# CORS_ORIGINS=https://your-production-domain.com

# ── File storage (local dev – no R2 vars = local disk fallback) ───────────────
UPLOAD_DIR=uploads

# ── File storage (Cloudflare R2 – production) ─────────────────────────────────
# R2_ACCOUNT_ID=your_cloudflare_account_id
# R2_ACCESS_KEY_ID=your_r2_access_key_id
# R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
# R2_BUCKET_NAME=wav-files

# ── Frontend API URL (Vercel – production build) ───────────────────────────────
# Set this on Vercel. Build command must replace the placeholder before nx build:
#   sed -i "s|__API_URL__|$API_URL|g" apps/wav-viewer/src/environments/environment.prod.ts && yarn nx build wav-viewer --configuration=production
# API_URL=https://your-api.example.com/api